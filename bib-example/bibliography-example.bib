@inproceedings{a.k.chaudharyEfficientDeepLearning2025,
  title = {An {{Efficient Deep Learning Approach}} for {{Skin Disease Prediction}} with {{On-Device Mobile Integration}}},
  booktitle = {2025 7th {{International Conference}} on {{Artificial Intelligence}} and {{Speech Technology}} ({{AIST}})},
  author = {{A. K. Chaudhary}},
  date = {2025-11-27/2025-11-28},
  pages = {1--6},
  doi = {10.1109/AIST68591.2025.11441493},
  abstract = {Skin diseases are common health issues and early detection is important to limit risks and to obtain better outcomes. But access to dermatologists is not always present, particularly in rural and underserved areas. In order to establish a bridge from these two parts we introduce a deep learning based skin disease prediction framework, which is both accurate and efficient to run in mobile devices. Using the dataset HAM10000 that contains images of seven types of skin lesions, we developed a light weight Convolutional Neural Network (CNN). This model has excellent performance and is computationally efficient. We augmented the images using preprocessing methods such as normalization and augmentation to improve the generalization the model. The trained CNN was then converted in TensorFlow Lite to integrate in a flutter-based Android app. This enables real-time predictions to be made on mobile devices by the model and does not require constant internet access. The accuracy of the system reached an accuracy of about 83\% and its performance is reliable for a number of lesion types as measured by recall and F1 scores. Unlike many other studies that focus more purely on the accuracy of the models in a controlled environment, we focus on the practical problems of accessibility and ease of use. This makes our system a promising tool for cheap and accessible dermatological screening in places where healthcare resources are limited.},
  eventtitle = {2025 7th {{International Conference}} on {{Artificial Intelligence}} and {{Speech Technology}} ({{AIST}})},
  keywords = {Accuracy,Computational modeling,Convolutional Neural Network (CNN),Convolutional neural networks,Deep learning,Deep Learning,Diseases,IEEE,Lesions,Medical Image Analysis,Mobile handsets,Mobile Health Application,P1 - IEEE,Performance evaluation,Predictive models,Skin,Skin Disease Prediction,TensorFlow Lite}
}
